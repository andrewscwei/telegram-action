{
  "name": "telegram-action",
  "version": "2.0.1",
  "description": "A GitHub Action for sending build status alerts to a Telegram chat",
  "private": true,
  "type": "module",
  "scripts": {
    "clean": "rimraf dist",
    "prebuild": "npm run clean && npm run lint",
    "build": "tsc",
    "test": "mocha -r dotenv/config --config=./.mocharc \"src/\"",
    "lint": "eslint",
    "lint:fix": "eslint --fix"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/andrewscwei/telegram-action"
  },
  "author": "Andrew Wei <andrewscwei@gmail.com>",
  "license": "MIT",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "@stylistic/eslint-plugin": "^5.10.0",
    "@types/chai": "^5.2.3",
    "@types/mocha": "^10.0.10",
    "@types/node": "^25.6.0",
    "chai": "^6.2.2",
    "dotenv": "^17.4.2",
    "eslint": "^10.2.0",
    "eslint-plugin-perfectionist": "^5.8.0",
    "jiti": "^2.6.1",
    "mocha": "^11.7.5",
    "rimraf": "^6.1.3",
    "semantic-release": "^25.0.3",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.1"
  },
  "dependencies": {
    "@actions/core": "^3.0.0",
    "@actions/github": "^9.1.0",
    "ansi-styles": "^6.2.3",
    "node-fetch": "^3.3.2"
  }
}
